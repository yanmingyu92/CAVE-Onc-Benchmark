                        sh:path cave:DTHDTC ] ] [ sh:property [ sh:hasValue "Y"^^xsd:string ;
                        sh:path cave:DTHFL ] ] ) ;
    sh:targetClass cave:DM .


cave:Shape_CORE-000008 a sh:NodeShape ;
