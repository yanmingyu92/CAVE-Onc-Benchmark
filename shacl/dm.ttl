@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


cave:Shape_CORE-000006 a sh:NodeShape ;
    rdfs:label "Record Data" ;
    rdfs:comment "ported from CORE-000006; demorgan; operators: non_empty,not_equal_to" ;
    prov:wasDerivedFrom "CORE-000006" ;
    sh:or ( [ sh:property [ sh:hasValue "Y"^^xsd:string ;
                        sh:path cave:DTHFL ] ] [ sh:property [ sh:maxCount 0 ;
                        sh:path cave:DTHFL ] ] ) ;
    sh:targetClass cave:DM .


cave:Shape_CORE-000007 a sh:NodeShape ;
    rdfs:label "Record Data" ;
    rdfs:comment "ported from CORE-000007; demorgan; operators: non_empty,not_equal_to" ;
    prov:wasDerivedFrom "CORE-000007" ;
