@prefix cave: <https://cave-onc.org/shacl/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


cave:Shape_CORE-000031 a sh:NodeShape ;
    rdfs:label "Record Data" ;
    rdfs:comment "ported from CORE-000031; demorgan; operators: exists" ;
    prov:wasDerivedFrom "CORE-000031" ;
    sh:property [ sh:maxCount 0 ;
            sh:path cave:QSEVAL ],
        [ sh:maxCount 0 ;
            sh:path cave:FTEVAL ] ;
    sh:targetClass cave:RS .


cave:Shape_CORE-000032 a sh:NodeShape ;
    rdfs:label "Record Data" ;
    rdfs:comment "ported from CORE-000032; demorgan; operators: exists" ;
    prov:wasDerivedFrom "CORE-000032" ;
    sh:property [ sh:maxCount 0 ;
            sh:path cave:QSEVALID ],
        [ sh:maxCount 0 ;
            sh:path cave:FTEVALID ] ;
    sh:targetClass cave:RS .
